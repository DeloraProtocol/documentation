                    "description": "Human-readable details. Validation errors may return multiple messages."
                  },
                  "errorCode": {
                    "type": "string"
                  },
                  "code": {
                    "oneOf": [
                      {
                        "type": "string"
                      },
                      {
                        "type": "number"
                      }
                    ]
                  },
                  "status": {
                    "oneOf": [
                      {
                        "type": "string"
                      },
                      {
                        "type": "number"
                      }
                    ]
                  }
                }
              },
              {
                "type": "string"
              },
              {
                "type": "array",
                "items": {
                  "type": "string"
                }
              }
            ],
            "example": {
              "message": [
                "One or more request parameters are invalid."
              ]
            }
          },
          "timestamp": {
            "type": "string",
            "example": "2026-05-13T18:00:00.000Z"
          },
          "path": {
            "type": "string",
            "example": "/v1/..."
          }
        },
        "required": [
          "statusCode",
          "code",
          "message",
          "timestamp"
        ]
      },
