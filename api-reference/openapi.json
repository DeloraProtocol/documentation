          {
            "name": "x-api-key",
            "in": "header",
            "description": "Optional API key for higher rate limits and fee rules.",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "chains",
            "required": false,
            "in": "query",
            "description": "Comma-separated chain IDs used to filter tokens.",
            "schema": {
              "example": "8453,1",
              "type": "string"
            }
          },
          {
            "name": "chainTypes",
            "required": false,
            "in": "query",
            "description": "Comma-separated chain types to include. Supported values: EVM, SVM.",
            "schema": {
              "example": "EVM,SVM",
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Tokens grouped by chain ID.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "additionalProperties": {
                    "type": "array",
                    "items": {
                      "$ref": "#/components/schemas/TokenDto"
                    }
                  },
                  "example": {
