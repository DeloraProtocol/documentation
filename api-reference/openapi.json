  "components": {
    "securitySchemes": {
      "api-key": {
        "type": "apiKey",
        "in": "header",
        "name": "x-api-key",
        "description": "Optional public API key for higher rate limits and fee rules."
      }
    },
    "schemas": {
      "TokenDto": {
        "type": "object",
        "properties": {
          "address": {
            "type": "string",
            "example": "0x833589fCD6eDb6E08f4c7C32D4f71b54bdA02913"
          },
          "symbol": {
            "type": "string",
            "example": "USDC"
          },
          "decimals": {
            "type": "number",
            "example": 6
          },
          "chainId": {
            "type": "number",
            "example": 8453
          },
          "name": {
            "type": "string",
            "example": "USD Coin"
          },
          "coinKey": {
            "type": "string",
            "example": "USDC"
          },
          "priceUSD": {
